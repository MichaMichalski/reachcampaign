# PostgreSQL connection string (external database)
DATABASE_URL="postgresql://user:password@your-postgres-host:5432/reachcampaign"

# Redis connection string (external Redis instance)
REDIS_URL="redis://default:password@your-redis-host:6379"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-change-this"
NEXTAUTH_URL="https://your-domain.com"

# 32-character key for encrypting sensitive data (API keys, SMTP credentials)
ENCRYPTION_KEY="your-32-char-encryption-key-here"
